  "Quote": [
    {
      "id": "b06e2ed9-72fa-4f5c-8b6e-36149ce977af",
      "text": "Faith grows quietly where compassion becomes natural.",
      "category": "Compassion",
      "is_featured": false,
      "display_order": 3,
      "is_active": true,
      "created_at": "2026-03-09T11:40:35.137Z",
      "updated_at": "2026-03-09T11:40:35.137Z"
    },
    {
      "id": "bb159f8a-8f6a-4dd8-abd8-58c41e46e742",
      "text": "Discipline is not punishment; it is the protection of the soul.",
      "category": "Inner Discipline",
      "is_featured": false,
      "display_order": 4,
      "is_active": true,
      "created_at": "2026-03-09T11:40:35.616Z",
      "updated_at": "2026-03-09T11:40:35.616Z"
    },
    {
      "id": "fc32fdaf-b997-4c9a-9c61-f6767618f5e7",
      "text": "The world changes slowly, but the heart can change in a single moment.",
      "category": "Self Awareness",
      "is_featured": false,
      "display_order": 5,
      "is_active": true,
      "created_at": "2026-03-09T11:40:35.878Z",
      "updated_at": "2026-03-09T11:40:35.878Z"
    },
    {
      "id": "d91e05f3-9a6f-4348-9b08-3ce4ea412ce2",
      "text": "Human beings search across the world for meaning, yet the doorway is always within their own awareness.",
      "category": "Self Awareness",
      "is_featured": true,
      "display_order": 0,
      "is_active": true,
      "created_at": "2026-03-09T11:40:36.120Z",
      "updated_at": "2026-03-09T11:40:36.120Z"
    },
    {
      "id": "754abffc-bb70-420b-bd34-31aeba3a3f0b",
      "text": "Compassion is not an act of will but a quality of understanding.",
      "category": "Compassion",
      "is_featured": false,
      "display_order": 6,
      "is_active": true,
      "created_at": "2026-03-09T11:40:36.376Z",
      "updated_at": "2026-03-09T11:40:36.376Z"
    },
    {
      "id": "f55a61b4-92d5-441d-b117-d8395142ad3c",
      "text": "True discipline arises from love of the goal, not fear of failure.",
      "category": "Inner Discipline",
      "is_featured": false,
      "display_order": 7,
      "is_active": true,
      "created_at": "2026-03-09T11:40:36.881Z",
      "updated_at": "2026-03-09T11:40:36.881Z"
    },
    {
      "id": "52f8cebf-c0f3-4565-954c-e5c79aabf4bd",
      "text": "Ethical conduct is not following rules but living from clarity.",
      "category": "Ethical Conduct",
      "is_featured": false,
      "display_order": 8,
      "is_active": true,
      "created_at": "2026-03-09T11:40:37.128Z",
      "updated_at": "2026-03-09T11:40:37.128Z"
    },
    {
      "id": "4e829e88-6f54-4f41-b72f-d49e1d07d896",
      "text": "We are not separate beings seeking connection; we are connection expressing as separate beings.",
      "category": "Human Unity",
      "is_featured": false,
      "display_order": 9,
      "is_active": true,
      "created_at": "2026-03-09T11:40:37.380Z",
      "updated_at": "2026-03-09T11:40:37.380Z"
    },
    {
      "id": "933392f2-320a-4a60-99c0-1258dcade30b",
      "text": "In silence, the mind finds its natural rhythm and the heart its native language.",
      "category": "Peace and Reflection",
      "is_featured": false,
      "display_order": 10,
      "is_active": true,
      "created_at": "2026-03-09T11:40:37.695Z",
      "updated_at": "2026-03-09T11:40:37.695Z"
    },
    {
      "id": "c64d4c02-4080-4272-b99b-68e765337b6d",
      "text": "Awareness is the mirror in which truth recognizes itself.",
      "category": "Self Awareness",
      "is_featured": false,
      "display_order": 11,
      "is_active": true,
      "created_at": "2026-03-09T11:40:38.356Z",
      "updated_at": "2026-03-09T11:40:38.356Z"
    },
    {
      "id": "c07e093e-c03d-4d57-93ac-3505d6f8d7c2",
      "text": "To be ethical is to act from understanding rather than from impulse.",
      "category": "Ethical Conduct",
      "is_featured": false,
      "display_order": 12,
      "is_active": true,
      "created_at": "2026-03-09T11:40:38.618Z",
      "updated_at": "2026-03-09T11:40:38.618Z"
    },
    {
      "id": "e344089d-245d-4fdf-a09f-0a384b9c070c",
      "text": "Unity is not something to achieve; it is something to recognize.",
      "category": "Human Unity",
      "is_featured": false,
      "display_order": 13,
      "is_active": true,
      "created_at": "2026-03-09T11:40:38.862Z",
      "updated_at": "2026-03-09T11:40:38.862Z"
    },
    {
      "id": "5d83fb09-b7f6-4adc-ad7c-f8c177a45530",
      "text": "Compassion begins where judgment ends.",
      "category": "Compassion",
      "is_featured": false,
      "display_order": 14,
      "is_active": true,
      "created_at": "2026-03-09T11:40:39.230Z",
      "updated_at": "2026-03-09T11:40:39.230Z"
    },
    {
      "id": "e3caa20d-aca1-4ffe-bf84-1cdbb440f35d",
      "text": "The quiet mind hears what the busy mind cannot imagine.",
      "category": "Peace and Reflection",
      "is_featured": false,
      "display_order": 15,
      "is_active": true,
      "created_at": "2026-03-09T11:40:41.245Z",
      "updated_at": "2026-03-09T11:40:41.245Z"
    },
    {
      "id": "54cfe4cd-08a4-44f9-9d03-019635cdb579",
      "text": "Self-observation is the first act of freedom.",
      "category": "Self Awareness",
      "is_featured": false,
      "display_order": 16,
      "is_active": true,
      "created_at": "2026-03-09T11:40:41.574Z",
      "updated_at": "2026-03-09T11:40:41.574Z"
    },
    {
      "id": "fab65000-060e-4d7e-94b2-477e90239deb",
      "text": "Consistency in small things creates the capacity for greatness in all things.",
      "category": "Inner Discipline",
      "is_featured": false,
      "display_order": 17,
      "is_active": true,
      "created_at": "2026-03-09T11:40:41.834Z",
      "updated_at": "2026-03-09T11:40:41.834Z"
    },
    {
      "id": "75186f8e-5252-4b0c-9b79-6964713b0eb4",
      "text": "Peace begins when the mind becomes honest with itself.",
      "category": "Peace and Reflection",
      "is_featured": false,
      "display_order": 2,
      "is_active": true,
      "created_at": "2026-03-09T11:40:34.872Z",
      "updated_at": "2026-03-09T11:43:43.407Z"
    },
    {
      "id": "2359ca1c-fead-4e57-8788-8e5acf6e6307",
      "text": "The heart becomes clear when it stops arguing with truth.",
      "category": "Self Awareness",
      "is_featured": false,
      "display_order": 1,
      "is_active": true,
      "created_at": "2026-03-09T11:40:32.728Z",
      "updated_at": "2026-03-09T11:43:44.569Z"
    }
  ],
