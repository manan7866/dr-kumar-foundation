# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore for Dr. Kumar Foundation Website
# Optimized for faster builds
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies (will be installed fresh)
node_modules
npm-debug.log
yarn-error.log
yarn.lock
pnpm-lock.yaml

# Build outputs
.next
out
build
dist

# Environment files (use Docker secrets or docker-compose env instead)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Git
.git
.gitignore
.gitattributes

# IDE and Editors
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# Testing
coverage
.nyc_output

# Documentation (keep essential ones, exclude others)
*.md
!package.json
!package-lock.json

# Docker (don't include Docker files in the image)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
docker/

# Prisma (keep schema and migrations, exclude dev files)
prisma/*.db
prisma/*.db-journal
# DON'T exclude migrations - they're needed for database setup

# Logs
logs
*.log
npm-debug.log*

# Temporary files
tmp
temp
.tmp
.temp

# Cache
.cache
.parcel-cache
.turbo
.npm-cache

# OS files
Thumbs.db
.Spotlight-V100
.Trashes

# Export files
dump.json
dump.sql
export-db.js
export-db.ts
