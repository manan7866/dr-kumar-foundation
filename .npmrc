# NPM Configuration for Better Reliability
# ─────────────────────────────────────────────────────────────────────────────

# Registry
registry=https://registry.npmjs.org/

# Retry settings
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=120000

# Network settings
maxsockets=50
https-proxy=null

# Cache settings
cache=.npm-cache
prefer-offline=false

# Log level
loglevel=error

# Progress bar (disable for CI/CD)
progress=false
